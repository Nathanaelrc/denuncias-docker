Options -Indexes -MultiViews
ServerSignature Off

# Seguridad de archivos sensibles
<FilesMatch "\.(env|log|sql|md|sh|ini|conf)$">
    Require all denied
</FilesMatch>

# Bloquear ejecución PHP en uploads
<If "%{REQUEST_URI} =~ m#^/uploads/#">
    <FilesMatch "\.php$">
        Require all denied
    </FilesMatch>
</If>

RewriteEngine On
RewriteBase /

# HTTPS redirect (descomentar en producción)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Añadir encabezados de seguridad
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# Directorio de archivos subidos — denegar PHP
RewriteRule ^uploads/.*\.php$ - [F,L]

# Si el archivo/directorio existe, servirlo directamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redirigir URLs con .php a URLs limpias (301)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+([^.]+)\.php(\?[^\s]*)?\s [NC]
RewriteRule ^ /%1 [R=301,L,QSA]

# Añadir .php internamente si el archivo existe
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^?]*)$ $1.php [L,QSA]

# Errores
ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php
