# =============================================
# Portal de Denuncias Empresa Portuaria Coquimbo - Apache Config
# URLs amigables sin extensión .php
# =============================================

RewriteEngine On
RewriteBase /

# =============================================
# SEGURIDAD
# =============================================

Options -Indexes

<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak|config|env)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.(?!htaccess)">
    Require all denied
</FilesMatch>

# Bloquear ejecución de PHP dentro de uploads (doble protección junto a uploads/.htaccess)
RewriteCond %{REQUEST_URI} ^/uploads/ [NC]
RewriteCond %{REQUEST_FILENAME} \.php[s345]?$ [NC]
RewriteRule ^ - [F,L]

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    # Cabecera HSTS: activar solo si el sitio opera bajo HTTPS permanente
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# =============================================
# FORZAR HTTPS (descomentar en producción con certificado válido)
# =============================================
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# =============================================
# OCULTAR EXTENSIONES .PHP
# =============================================

# 1. Redirigir URLs con .php a URLs limpias (301)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+([^.]+)\.php(\?[^\s]*)?\s [NC]
RewriteRule ^ /%1 [R=301,L,QSA]

# 2. No procesar archivos y directorios existentes
RewriteCond %{REQUEST_FILENAME} -d [OR]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 3. Añadir .php internamente si el archivo existe
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^?]*)$ $1.php [L,QSA]

# =============================================
# ERRORES
# =============================================

ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php
